# =============================================
# LOVENSE BACKEND - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Your Lovense Developer Token (from developer.lovense.com dashboard)
# KEEP THIS SERVER-SIDE ONLY - never expose to frontend
LOVENSE_DEV_TOKEN=your_developer_token_here

# Port your Express server listens on
PORT=3000

# Your public backend URL (your Render URL once deployed)
# Example: https://your-app.onrender.com
PUBLIC_BACKEND_URL=https://your-app.onrender.com

# A secret you generate for verifying Lovense callback payloads
# Use any random string - this goes in your callback validation logic
CALLBACK_SECRET=your_random_secret_here
