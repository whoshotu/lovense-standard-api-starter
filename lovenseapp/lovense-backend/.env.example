# =============================================
# LOVENSE BACKEND - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# Add all 3 Lovense secrets as Environment Variables in Render dashboard

# -------------------------------------------------
# FROM YOUR LOVENSE DEVELOPER DASHBOARD
# Get all 3 at: https://developer.lovense.com
# -------------------------------------------------

# 1. Your Lovense Developer Token
#    Used server-side for QR/auth requests
#    NEVER expose this to frontend code
LOVENSE_DEV_TOKEN=your_developer_token_here

# 2. AES Key (32 characters)
#    Used to decrypt incoming callback payloads from Lovense
LOVENSE_AES_KEY=your_aes_key_here

# 3. AES IV (16 characters)
#    Used alongside AES Key to decrypt callback payloads
LOVENSE_AES_IV=your_aes_iv_here

# -------------------------------------------------
# YOUR SERVER CONFIG
# -------------------------------------------------

# Port your Express server listens on (Render sets this automatically)
PORT=3000

# Your public backend URL (your Render URL once deployed)
# Example: https://lovense-standard-api-starter.onrender.com
PUBLIC_BACKEND_URL=https://your-app.onrender.com
